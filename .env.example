# Odoo (XML-RPC, mismo host que el navegador)
ODOO_URL=http://127.0.0.1:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# OpenAI (embeddings + respuesta; obligatorio con el stack por defecto)
OPENAI_API_KEY=

# Modelos (opcional)
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Indexación
ODOO_RAG_RECORD_LIMIT=400
ODOO_RAG_STORAGE_DIR=storage

# Web UI (python -m odoo_rag web)
ODOO_RAG_WEB_HOST=127.0.0.1
ODOO_RAG_WEB_PORT=8787
